<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SmartGymTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SmartGymSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="SmartGymPrimaryButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_premium_button</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
    </style>

    <style name="SmartGymInputField">
        <item name="android:background">@drawable/bg_premium_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

</resources>
