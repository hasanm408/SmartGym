<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_accent_chip"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/white"
            android:textSize="60sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBookingTitle"
            style="@style/SmartGymTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Booking Confirmed!"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvBookingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Your session has been scheduled successfully."
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnBackToDashboard"
            style="@style/SmartGymPrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Go to Dashboard" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
