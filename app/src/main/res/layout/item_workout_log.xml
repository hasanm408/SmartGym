<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvExName"
            style="@style/SmartGymSectionHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exercise Name"
            android:textColor="@color/primary" />

        <TextView
            android:id="@+id/tvExTarget"
            style="@style/SmartGymSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target: 3 Sets x 12 Reps" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etLogWeight"
                style="@style/SmartGymEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Weight (kg)"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/etLogReps"
                style="@style/SmartGymEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Reps"
                android:inputType="number" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbCompleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mark as Complete"
            android:textColor="@color/text_secondary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
