<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Placeholder for Avatar -->
        <View
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_accent_chip" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTrainerName"
                style="@style/SmartGymSectionHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trainer Name" />

            <TextView
                android:id="@+id/tvTrainerInfo"
                style="@style/SmartGymSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Exp: 5 Years | Age: 28" />

            <TextView
                android:id="@+id/tvTrainerTime"
                style="@style/SmartGymSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="7:00 AM Daily"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnViewDetails"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/primary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
